# ───────────────────────────────────────────────────────────────
# APPLICATION CONFIG
# ───────────────────────────────────────────────────────────────
APP_NAME=Innerspace
APP_ENV=local
APP_DEBUG=true

# ───────────────────────────────────────────────────────────────
# DATABASE CONFIG
# ───────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_DATABASE=innerspace-dev
DB_USERNAME=innerspace-dev
DB_PASSWORD=secret


# ───────────────────────────────────────────────────────────────
# MAILER CONFIG
# ───────────────────────────────────────────────────────────────
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_USERNAME=mail@example.com
SMTP_PASSWORD=secret
SMTP_ENCRYPTION=tls